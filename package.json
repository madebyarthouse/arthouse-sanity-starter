{
  "name": "arthouse-sanity-starter-react",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "rr:typegen": "react-router typegen",
    "sanity:dev": "sanity dev",
    "sanity:build": "sanity build",
    "sanity:deploy": "sanity deploy",
    "sanity:extract": "sanity schema extract --path ./app/sanity/schema.json",
    "sanity:typegen": "sanity typegen generate",
    "sanity:types": "pnpm sanity:extract && pnpm sanity:typegen",
    "format": "prettier --write .",
    "typecheck": "pnpm sanity:types && pnpm rr:typegen && tsc --noEmit"
  },
  "dependencies": {
    "@c15t/react": "^1.8.2",
    "@portabletext/react": "^3.2.1",
    "@react-router/node": "^7.7.1",
    "@react-router/serve": "^7.7.1",
    "@sanity/client": "^7.9.0",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.0.2",
    "@sanity/preview-url-secret": "^2.1.14",
    "@sanity/react-loader": "^1.11.18",
    "@sanity/vision": "^4.5.0",
    "@sanity/visual-editing": "^3.0.3",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "clsx": "^2.1.1",
    "groq": "^4.5.0",
    "isbot": "^5.1.27",
    "posthog-js": "^1.307.2",
    "pretty-cache-header": "^1.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-dropzone": "^14.3.8",
    "react-router": "^7.7.1",
    "sanity": "^4.5.0",
    "sanity-plugin-asset-source-unsplash": "^7.0.0",
    "sanity-plugin-media": "^4.1.0",
    "styled-components": "^6.1.19"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@react-router/dev": "^7.7.1",
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^20",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^9.33.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.40.0",
    "vite": "^6.3.3",
    "vite-tsconfig-paths": "^5.1.4"
  }
}