# --- Sanity (required) ---
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=

# Optional (defaults are OK)
VITE_SANITY_API_VERSION=2024-02-13
VITE_SANITY_STUDIO_URL=
VITE_SANITY_STUDIO_PREVIEW_ORIGIN=http://localhost:5173

# --- Preview / Presentation mode (server-only) ---
# Used to fetch drafts in preview mode.
SANITY_READ_TOKEN=

# Used to sign the preview cookie.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SANITY_SESSION_SECRET=
