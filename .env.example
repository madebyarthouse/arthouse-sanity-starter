# Copy to .env for local development

# ------------------------------
# Sanity (public, safe in client)
# ------------------------------
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-02-13
# Embedded Studio URL (used for visual editing)
VITE_SANITY_STUDIO_URL=http://localhost:5173/studio

# ------------------------------
# Sanity (private, server-only)
# ------------------------------
# Preferred token name
SANITY_API_READ_TOKEN=
# Back-compat token name (optional)
SANITY_READ_TOKEN=

# Cookie session secret for preview mode
SANITY_SESSION_SECRET=please-change-me

# Presentation preview origin (production domain)
VITE_SANITY_STUDIO_PREVIEW_ORIGIN=
SANITY_STUDIO_PREVIEW_ORIGIN=

# ------------------------------
# Site
# ------------------------------
# Canonical site URL (used by sitemap/robots)
SITE_URL=
# Optional platform-provided URL fallback
PRODUCTION_URL=
