# Copy to .env for local development

# ------------------------------
# Sanity (public, safe in client)
# ------------------------------
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-02-13
# Embedded Studio URL (used for visual editing)
VITE_SANITY_STUDIO_URL=http://localhost:5173/studio

# ------------------------------
# Sanity (private, server-only)
# ------------------------------
# Preferred token name
SANITY_API_READ_TOKEN=
# Back-compat token name (optional)
SANITY_READ_TOKEN=

# Cookie session secret for preview mode
SANITY_SESSION_SECRET=please-change-me

# ------------------------------
# Deployment
# ------------------------------
# change me: target provider (custom, vercel, cloudflare)
DEPLOYMENT_TARGET=change me
# change me: local app origin fallback (supports multiple local instances)
DEPLOYMENT_LOCAL_ORIGIN=change me
# change me: canonical production origin
DEPLOYMENT_PRODUCTION_ORIGIN=change me
# change me: explicit preview/staging origin override
DEPLOYMENT_PREVIEW_ORIGIN=change me

# Platform-specific deployment values (optional)
# change me: Vercel preview/production host (without protocol is fine)
VERCEL_URL=change me
# change me: Vercel environment (production, preview, development)
VERCEL_ENV=change me
# change me: Cloudflare Pages URL
CF_PAGES_URL=change me
